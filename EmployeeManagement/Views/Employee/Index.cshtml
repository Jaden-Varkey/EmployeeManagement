@{
    Layout = null; // This ensures we don't rely on a broken layout file
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Employee Management</title>

    <!-- Bootstrap 5 CSS for styling and centralizing -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- DataTables CSS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/rowgroup/1.4.1/css/rowGroup.dataTables.min.css" />
    <!-- jQuery UI-->
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css">

    <style>
            /* Custom CSS to center the form on the screen */
            body {
                background-color: #f4f7f6;
                padding-top: 40px;
                padding-bottom: 40px;
            }

            .main-container {
                max-width: 1450px;
                margin: 0 auto; /* This centralizes the div */
                background: #ffffff;
                padding: 30px;
                border-radius: 10px;
                box-shadow: 0 4px 8px rgba(0,0,0,0.1);
            }

            /* --- Virtual scroll (windowing) layout ---
               #viewport is the only element that scrolls. #spacer is an empty block sized to the
               FULL list height so the scrollbar behaves as if every row were present; #content is
               absolutely positioned over it and holds only the handful of currently-visible rows,
               shifted into place with translateY. ROW_HEIGHT in the script MUST equal .v-row's
               height or the math drifts. */
            #viewport {
                position: relative;
                height: 600px;
                overflow-y: auto;
                border: 1px solid #dee2e6;
                border-top: none;
            }
            #content { position: absolute; top: 0; left: 0; right: 0; }
            .v-header, .v-row { display: flex; align-items: center; padding: 0 8px; box-sizing: border-box; }
            .v-row { height: 44px; border-bottom: 1px solid #dee2e6; }
            .v-header {
                height: 44px;
                font-weight: bold;
                background: #f8f9fa;
                border: 1px solid #dee2e6;
                border-bottom: 2px solid #dee2e6;
            }
            .v-cell { padding: 0 6px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    </style>
</head>
<body>

    <div class="main-container">
        <!-- Input Form Section -->
        <div class="card shadow-sm mb-5 border-primary">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h4 class="mb-0">Batch Employee Entry</h4>
            </div>
            <div class="card-body p-2">
                <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                    <table class="table table-bordered table-sm align-middle" id="bulkEntryTable">
                        <thead class="table-light sticky-top">
                            <tr>
                                <th style="min-width: 150px;">Full Name</th>
                                <th style="min-width: 220px;">Phone Number</th>
                                <th style="min-width: 70px;">Age</th>
                                <th style="min-width: 200px;">Address</th>
                                <th style="min-width: 140px;">Gender</th>
                                <th style="min-width: 250px;">Department</th>
                                <th style="min-width: 130px;">Adm. Date</th>
                                <th style="min-width: 135px;">Status</th>
                                <th style="min-width: 50px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-between mt-3 px-2 pb-2">
                    <button type="button" class="btn btn-outline-primary fw-bold" id="btnAddRow">➕ Add Row</button>
                    <button type="button" class="btn btn-success fw-bold px-5" id="btnSaveBatch">🚀 Save All to Database</button>
                </div>
            </div>
        </div>

        <!-- Search Bar Panel -->
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-secondary text-white">
                <h5 class="mb-0">Search & Filter</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label fw-bold">Name</label>
                        <input type="text" id="searchName" class="form-control" placeholder="Start typing name..." />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-bold">Employee ID</label>
                        <input type="number" id="searchId" class="form-control" placeholder="ID No." />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-bold">Date From</label>
                        <input type="date" id="searchStartDate" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-bold">Date To</label>
                        <input type="date" id="searchEndDate" class="form-control" />
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <button type="button" id="btnClear" class="btn btn-outline-secondary w-100">Clear</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Data Table Section -->
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white">
                <h4 class="mb-0">Employee Directory</h4>
            </div>
            <div class="card-body">
                <!-- Lazy mode renders collapsible department folders here; eager/flat modes use the table below. -->
                <div id="deptAccordion"></div>

                <!-- Virtual-scroll mode renders here: a fixed column header above a windowed viewport
                     that only ever holds the visible rows (see DIRECTORY_MODE 'virtual'). -->
                <div id="virtualWrap" style="display:none;">
                    <div class="v-header">
                        <div class="v-cell" style="flex:2">Full Name</div>
                        <div class="v-cell" style="flex:2">Phone</div>
                        <div class="v-cell" style="flex:1">Age</div>
                        <div class="v-cell" style="flex:1">Gender</div>
                        <div class="v-cell" style="flex:2">Department</div>
                        <div class="v-cell" style="flex:1">Admission Date</div>
                        <div class="v-cell" style="flex:1">Status</div>
                    </div>
                    <div id="viewport">
                        <div id="spacer"></div>
                        <div id="content"></div>
                    </div>
                </div>

                <table id="EmployeeTable" class="table table-striped table-bordered w-100">
                    <thead>
                        <tr>
                            <th>Full Name</th>
                            <th>Phone</th>
                            <th>Age</th>
                            <th>Gender</th>
                            <th>Department</th>
                            <th>Admission Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>
    </div>

    <!-- REQUIRED SCRIPTS -->
    <!-- jQuery MUST be loaded first -->
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <!-- jQuery UI -->
    <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"></script>
    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- DataTables JS -->
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/rowgroup/1.4.1/js/dataTables.rowGroup.min.js"></script>
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <!-- libphonenumber-js (max bundle = full metadata, so getType() works) for client-side,
         all-country phone validation. The server still re-validates; this is just fast UX feedback. -->
    <script src="https://cdn.jsdelivr.net/npm/libphonenumber-js@1.11.17/bundle/libphonenumber-max.min.js"></script>

    <script>
        // Country-code <option> list, generated server-side from libphonenumber's supported
        // regions (see EmployeeController.BuildCountryCodeOptions). Injected once and reused
        // for every dynamically-added grid row.
        const COUNTRY_OPTIONS = `@Html.Raw(ViewBag.CountryCodeOptions)`;

        // === DIRECTORY MODE SWITCH ===
        // How the Employee Directory renders. Hard switch: change the default below.
        // Live switch (no rebuild): load the page with ?mode=lazy | ?mode=eager | ?mode=flat.
        //   lazy  (default) – collapsible department folders; a department's employees load
        //                     ONLY when its folder is expanded. Tiny initial render, fast.
        //   eager           – original rowGroup table: every row fetched & rendered hidden.
        //                     The slow "before" (kept for the demo comparison).
        //   flat            – server-side paginated table, 25 rows per page, no grouping.
        //   virtual         – virtual scrolling (windowing): fetch the whole filtered list once,
        //                     but only ever keep the rows visible in the viewport in the DOM. As
        //                     you scroll, that small window is recycled, so scrolling stays smooth
        //                     on desktop and mobile no matter how many thousands of rows exist.
        const DIRECTORY_MODE = (new URLSearchParams(location.search).get('mode')) || 'lazy';
        // === END DIRECTORY MODE SWITCH ===

        // === REDIS LIVE SWITCH ===
        // Forwarded to every directory request so the whole app can run uncached on demand.
        // Live off-switch (no rebuild): load any page with ?cache=false. (The server also has a
        // hard EnableRedisCache flag in EmployeeController.) Default: caching ON.
        const USE_CACHE = (new URLSearchParams(location.search).get('cache') !== 'false');
        // === END REDIS LIVE SWITCH ===

        // === DEPARTMENT PAGING SWITCH (option 2) ===
        // When ON (default), expanding a department loads DEPT_PAGE_SIZE rows at a time with
        // Prev/Next, so a 10k-person department renders 25 rows instead of all at once.
        // Live off-switch: ?deptpaging=false loads the whole department at once (old behaviour).
        const ENABLE_DEPT_PAGING = (new URLSearchParams(location.search).get('deptpaging') !== 'false');
        const DEPT_PAGE_SIZE = 25;
        // === END DEPARTMENT PAGING SWITCH ===

        $(document).ready(function () {

        // --- ADMISSION DATE CONSTRAINTS ---
        const today = new Date();
        const maxFutureDate = new Date();
        maxFutureDate.setDate(today.getDate() + 30); // 30 days in advance
        const yyyy = maxFutureDate.getFullYear();
        const mm = String(maxFutureDate.getMonth() + 1).padStart(2, '0');
        const dd = String(maxFutureDate.getDate()).padStart(2, '0');
        const maxDateString = `${yyyy}-${mm}-${dd}`;
        const currentYyyy = today.getFullYear();
        const currentMm = String(today.getMonth() + 1).padStart(2, '0');
        const currentDd = String(today.getDate()).padStart(2, '0');
        const currentDateString = `${currentYyyy}-${currentMm}-${currentDd}`;

        // --- PHONE VALIDATION (client-side, every country) ---
        // Uses libphonenumber-js (loaded above) so every code in the dropdown gets real
        // per-country validation, not just a hardcoded few. This is a UX convenience ONLY:
        // EmployeeController.ValidatePhone re-checks AND normalizes on the server, which is the
        // source of truth and can't be bypassed. Returns an error string, or null when valid.
        function validatePhoneClient(code, phone) {
            if (!phone) return 'Phone Number is required.';
            if (typeof libphonenumber === 'undefined') return null; // CDN blocked — let the server validate
            let parsed;
            try {
                parsed = libphonenumber.parsePhoneNumber(code + phone);
            } catch (e) {
                return `Enter a valid phone number for ${code}.`;
            }
            if (!parsed || !parsed.isValid()) {
                return `Enter a valid phone number for ${code}.`;
            }
            // Match the server: only mobile / landline, no premium-rate / toll-free / special.
            const type = parsed.getType();
            if (type && ['MOBILE', 'FIXED_LINE', 'FIXED_LINE_OR_MOBILE'].indexOf(type) === -1) {
                return "Enter a mobile or landline number (premium-rate, toll-free, and special-service numbers aren't allowed).";
            }
            return null;
        }

        // Validates a single entry row. Returns an array of error strings (empty = valid).
        // This is used INSTEAD of checkValidity() because the real-time input filters call
        // .val(...) on every keystroke, which clears the input's "dirty" flag and stops
        // HTML5 minlength/tooShort checks from ever firing (that was the 5-digit-phone bug).
        function getRowErrors($row) {
            const errors = [];
            const name    = ($row.find('.excel-name').val()    || '').trim();
            const code    =  $row.find('.excel-code').val();
            const phone   = ($row.find('.excel-phone').val()   || '').trim();
            const ageRaw  = ($row.find('.excel-age').val()      || '').trim();
            const address = ($row.find('.excel-address').val()  || '').trim();
            const gender  =  $row.find('.excel-gender').val();
            const dept    =  $row.find('.excel-dept').val();
            const date    =  $row.find('.excel-date').val();
            const status  =  $row.find('.excel-status').val();
            const age     = parseInt(ageRaw, 10);

            if (name.length < 2) {
                errors.push('Full Name is required (at least 2 letters).');
            } else if (!/^[a-zA-Z\s]+$/.test(name)) {
                errors.push('Full Name can only contain letters and spaces.');
            }

            const phoneError = validatePhoneClient(code, phone);
            if (phoneError) {
                errors.push(phoneError);
            }

            if (ageRaw === '' || isNaN(age) || age < 18 || age > 100) {
                errors.push('Age must be between 18 and 100.');
            }
            if (address.length < 10) {
                errors.push('Address must be at least 10 characters long.');
            }
            if (!gender) errors.push('Please select a gender.');
            if (!dept)   errors.push('Please select a department.');
            if (!status) errors.push('Please select an employment status.');
            if (!date) {
                errors.push('Admission date is required.');
            } else if (date < '2018-01-01' || date > maxDateString) {
                errors.push(`Admission date must be between 01/01/2018 and ${dd}/${mm}/${yyyy}.`);
            }

            return errors;
        }

        // 2. Initialize the Employee Directory (lazy / eager / flat — see DIRECTORY_MODE).
        var expandedGroups = {};    // (eager mode) which departments are expanded; default collapsed
        var table = null;           // DataTable instance in eager/flat modes; stays null in lazy mode

        // Shared dd/mm/yyyy formatter, used by the DataTable date column AND the lazy folder tables.
        function formatDate(data) {
        if (!data) return "";
        var d = new Date(data);
        return ("0" + d.getDate()).slice(-2) + "/" + ("0" + (d.getMonth() + 1)).slice(-2) + "/" + d.getFullYear();
        }

        // Current search-panel filters, sent with every directory request.
        function collectFilters() {
        return {
        searchName: $('#searchName').val(),
        searchId: $('#searchId').val(),
        startDate: $('#searchStartDate').val(),
        endDate: $('#searchEndDate').val(),
        cache: USE_CACHE   // forwarded so ?cache=false disables Redis for these requests too
        };
        }

        // Re-render the directory after a search / clear / save, whichever mode is active.
        function refreshDirectory() {
        if (DIRECTORY_MODE === 'lazy') loadDeptSummary();
        else if (DIRECTORY_MODE === 'virtual') loadVirtual();
        else if (table) table.ajax.reload();
        }

        // ---- LAZY MODE HELPERS ----
        function escapeHtml(s) { return $('<div/>').text(s == null ? '' : s).html(); }

        function folderLabel(icon, dept, count) {
        return icon + ' ' + escapeHtml(dept) + ' (' + count + ' Employees)';
        }

        // Builds the inner employee table shown when a department folder is expanded.
        function buildDeptTable(rows) {
        if (!rows || !rows.length) return '<div class="text-muted p-2">No employees.</div>';
        var html = '<table class="table table-sm table-striped mb-0"><thead><tr>'
        + '<th>Full Name</th><th>Phone</th><th>Age</th><th>Gender</th><th>Admission Date</th><th>Status</th>'
        + '</tr></thead><tbody>';
        rows.forEach(function (e) {
        html += '<tr>'
        + '<td>' + escapeHtml(e.fullName) + '</td>'
        + '<td>' + escapeHtml(e.phoneNumber) + '</td>'
        + '<td>' + e.age + '</td>'
        + '<td>' + escapeHtml(e.gender) + '</td>'
        + '<td>' + formatDate(e.admissionDate) + '</td>'
        + '<td>' + escapeHtml(e.employmentStatus) + '</td>'
        + '</tr>';
        });
        return html + '</tbody></table>';
        }

        // Prev/Next pager bar shown under a department's rows when in-department paging is on.
        function buildPager(start, total) {
        var from = total === 0 ? 0 : start + 1;
        var to = Math.min(start + DEPT_PAGE_SIZE, total);
        var prevDisabled = start <= 0 ? 'disabled' : '';
        var nextDisabled = (start + DEPT_PAGE_SIZE) >= total ? 'disabled' : '';
        return '<div class="d-flex justify-content-between align-items-center p-2">'
        + '<span class="text-muted small">Showing ' + from + '–' + to + ' of ' + total + '</span>'
        + '<span>'
        + '<button type="button" class="btn btn-sm btn-outline-secondary dept-prev" ' + prevDisabled + '>← Prev</button> '
        + '<button type="button" class="btn btn-sm btn-outline-secondary dept-next" ' + nextDisabled + '>Next →</button>'
        + '</span></div>';
        }

        // OPTION 2 ON: load one DEPT_PAGE_SIZE page of a department (25 rows) + a pager bar.
        function loadDeptPage($folder, start) {
        var $body = $folder.find('.dept-body');
        var dept = $folder.data('dept');
        $body.html('<div class="text-muted p-2">Loading…</div>');
        var params = $.extend({ department: dept, start: start, length: DEPT_PAGE_SIZE }, collectFilters());
        $.getJSON('/Employee/GetEmployeesByDepartment', params)
        .done(function (resp) {
        var total = (resp.total != null) ? resp.total : (resp.data ? resp.data.length : 0);
        $body.html(buildDeptTable(resp.data) + buildPager(start, total));
        $folder.data('loaded', true);
        $folder.data('start', start);
        })
        .fail(function () {
        $body.html('<div class="text-danger p-2">Failed to load employees.</div>');
        });
        }

        // OPTION 2 OFF: load the whole department at once (the pre-paging behaviour).
        function loadDeptAll($folder) {
        var $body = $folder.find('.dept-body');
        var dept = $folder.data('dept');
        $body.html('<div class="text-muted p-2">Loading…</div>');
        $.getJSON('/Employee/GetEmployeesByDepartment', $.extend({ department: dept }, collectFilters()))
        .done(function (resp) {
        $body.html(buildDeptTable(resp.data));
        $folder.data('loaded', true);
        })
        .fail(function () {
        $body.html('<div class="text-danger p-2">Failed to load employees.</div>');
        });
        }

        // Pager button clicks (delegated; only present when in-department paging is on).
        $('#deptAccordion').on('click', '.dept-next', function () {
        var $folder = $(this).closest('.dept-folder');
        loadDeptPage($folder, ($folder.data('start') || 0) + DEPT_PAGE_SIZE);
        });
        $('#deptAccordion').on('click', '.dept-prev', function () {
        var $folder = $(this).closest('.dept-folder');
        loadDeptPage($folder, Math.max(0, ($folder.data('start') || 0) - DEPT_PAGE_SIZE));
        });

        // Fetches the (filtered) per-department headcounts and renders one collapsed folder each.
        function loadDeptSummary() {
        var $acc = $('#deptAccordion').html('<div class="text-muted p-3">Loading departments…</div>');
        $.getJSON('/Employee/GetDepartmentSummary', collectFilters())
        .done(function (list) {
        $acc.empty();
        if (!list || !list.length) {
        $acc.html('<div class="text-muted p-3">No employees match your search.</div>');
        return;
        }
        list.forEach(function (d) {
        var $folder = $(
        '<div class="dept-folder border rounded mb-2">' +
        '<div class="dept-header p-2" style="cursor:pointer;color:#0d6efd;font-weight:bold;">' +
        folderLabel('➕', d.department, d.count) +
        '</div>' +
        '<div class="dept-body" style="display:none;"></div>' +
        '</div>'
        );
        $folder.data('dept', d.department);
        $folder.data('count', d.count);
        $folder.data('loaded', false);
        $acc.append($folder);
        });
        })
        .fail(function () {
        $acc.html('<div class="text-danger p-3">Failed to load departments.</div>');
        });
        }

        // Expand / collapse a folder; lazy-load its employees the first time it's opened.
        $('#deptAccordion').on('click', '.dept-header', function () {
        var $folder = $(this).closest('.dept-folder');
        var $body = $folder.find('.dept-body');
        var dept = $folder.data('dept');
        var count = $folder.data('count');

        if ($body.is(':visible')) {                     // collapse
        $body.hide();
        $(this).html(folderLabel('➕', dept, count));
        return;
        }

        $(this).html(folderLabel('➖', dept, count));    // expand
        $body.show();
        if ($folder.data('loaded')) return;             // rows already fetched once

        // Option 2: load the first 25-row page; otherwise load the whole department at once.
        if (ENABLE_DEPT_PAGING) loadDeptPage($folder, 0);
        else loadDeptAll($folder);
        });

        // ---- VIRTUAL SCROLL (WINDOWING) HELPERS ----
        // ROW_HEIGHT must match .v-row's CSS height exactly, since the visible window is derived
        // from scroll position by arithmetic (no per-row measuring).
        var ROW_HEIGHT = 44;
        var OVERSCAN = 6;            // extra rows rendered above & below the viewport to hide gaps while scrolling
        var allEmployees = [];       // the FULL dataset, fetched once and kept in memory (the master copy)
        var virtualData = [];        // the currently-visible subset after client-side filtering — NOT in the DOM
        var _vRendering = false;     // reentrancy guard so overlapping animation frames don't double-render

        // One fixed-height row of the windowed list.
        function vRowHtml(e) {
        return '<div class="v-row">'
        + '<div class="v-cell" style="flex:2">' + escapeHtml(e.fullName) + '</div>'
        + '<div class="v-cell" style="flex:2">' + escapeHtml(e.phoneNumber) + '</div>'
        + '<div class="v-cell" style="flex:1">' + e.age + '</div>'
        + '<div class="v-cell" style="flex:1">' + escapeHtml(e.gender) + '</div>'
        + '<div class="v-cell" style="flex:2">' + escapeHtml(e.department) + '</div>'
        + '<div class="v-cell" style="flex:1">' + formatDate(e.admissionDate) + '</div>'
        + '<div class="v-cell" style="flex:1">' + escapeHtml(e.employmentStatus) + '</div>'
        + '</div>';
        }

        // Render only the rows currently in (or just outside) the viewport, and offset #content so
        // they line up with the scrollbar position. Called on every scroll frame.
        function renderVirtual() {
        if (_vRendering) return;
        _vRendering = true;

        var $vp = $('#viewport');
        var scrollTop = $vp.scrollTop();
        var viewH = $vp.height();

        var start = Math.max(0, Math.floor(scrollTop / ROW_HEIGHT) - OVERSCAN);
        var end = Math.min(virtualData.length, Math.ceil((scrollTop + viewH) / ROW_HEIGHT) + OVERSCAN);

        $('#content').css('transform', 'translateY(' + (start * ROW_HEIGHT) + 'px)');

        var html = '';
        for (var i = start; i < end; i++) html += vRowHtml(virtualData[i]);
        $('#content').html(html);

        _vRendering = false;
        }

        // Size the spacer to the full list height and wire the scroll handler (throttled to one
        // render per animation frame, which is what keeps scrolling smooth on web and mobile).
        function initVirtual() {
        $('#spacer').height(virtualData.length * ROW_HEIGHT);
        $('#viewport').off('scroll.virtual').on('scroll.virtual', function () {
        window.requestAnimationFrame(renderVirtual);
        }).scrollTop(0);
        renderVirtual();
        }

        // Fetch the WHOLE dataset once into memory. After this, searching/filtering is done
        // entirely client-side (see applyClientFilter) — no further server requests per search,
        // because every row is already here in allEmployees.
        function loadVirtual() {
        $('#content').css('transform', 'none').html('<div class="text-muted p-3">Loading…</div>');
        $.getJSON('/Employee/GetEmployees', { cache: USE_CACHE }) // no search params: load everything
        .done(function (resp) {
        allEmployees = (resp && resp.data) ? resp.data : [];
        applyClientFilter(); // render with whatever is currently in the search panel
        })
        .fail(function () {
        $('#content').css('transform', 'none').html('<div class="text-danger p-3">Failed to load employees.</div>');
        });
        }

        // Filter the in-memory master list against the search panel and re-render — instantly,
        // with zero network. Name = case-insensitive "contains"; ID = exact; dates = inclusive range.
        function applyClientFilter() {
        var name = ($('#searchName').val() || '').trim().toLowerCase();
        var id = ($('#searchId').val() || '').trim();
        var startD = $('#searchStartDate').val();
        var endD = $('#searchEndDate').val();

        virtualData = allEmployees.filter(function (e) {
        if (name && (e.fullName || '').toLowerCase().indexOf(name) === -1) return false;
        if (id && String(e.id) !== id) return false;
        var ad = (e.admissionDate || '').slice(0, 10); // YYYY-MM-DD, so string compare = date compare
        if (startD && ad < startD) return false;
        if (endD && ad > endD) return false;
        return true;
        });

        if (!virtualData.length) {
        $('#spacer').height(0);
        $('#content').css('transform', 'none').html('<div class="text-muted p-3">No employees found.</div>');
        return;
        }
        initVirtual();
        }

        // ---- MODE INITIALISATION ----
        if (DIRECTORY_MODE === 'lazy') {
        $('#EmployeeTable').hide();
        $('#deptAccordion').show();
        loadDeptSummary();
        } else if (DIRECTORY_MODE === 'virtual') {
        $('#EmployeeTable').hide();
        $('#deptAccordion').hide();
        $('#virtualWrap').show();
        loadVirtual();
        } else {
        $('#deptAccordion').hide();

        // Department column: a normal column in flat mode; hidden in eager mode (rowGroup reads it).
        var columns = [
        { "data": "fullName" },
        { "data": "phoneNumber" },
        { "data": "age" },
        { "data": "gender" },
        { "data": "department", "visible": DIRECTORY_MODE === 'flat' },
        { "data": "admissionDate", "render": function (data) { return formatDate(data); } },
        { "data": "employmentStatus" }
        ];

        var tableOptions = {
        "processing": true,
        "ajax": {
        "url": "/Employee/GetEmployees",
        "type": "GET",
        "datatype": "json",
        "data": function (d) {
        d.searchName = $('#searchName').val();
        d.searchId = $('#searchId').val();
        d.startDate = $('#searchStartDate').val();
        d.endDate = $('#searchEndDate').val();
        d.cache = USE_CACHE; // forwarded so ?cache=false disables Redis here too
        }
        },
        "columns": columns
        };

        if (DIRECTORY_MODE === 'flat') {
        // SERVER-SIDE PAGINATION: one 25-row page at a time. Tiny payload, instant render.
        tableOptions.serverSide = true;
        tableOptions.paging = true;
        tableOptions.info = true;
        tableOptions.pageLength = 25;
        tableOptions.lengthMenu = [10, 25, 50, 100];
        tableOptions.order = [[0, 'asc']];
        } else {
        // EAGER GROUPED (original behaviour): pull EVERY row and group by department with
        // collapsible folders — renders all 50k rows hidden. This is the slow "before".
        tableOptions.paging = false;
        tableOptions.info = false;
        tableOptions.orderFixed = [4, 'asc'];
        tableOptions.order = [[0, 'asc']];
        tableOptions.rowGroup = {
        dataSrc: 'department',
        startRender: function (rows, group) {
        var isExpanded = !!expandedGroups[group];
        rows.nodes().each(function (r) { r.style.display = isExpanded ? '' : 'none'; });
        var toggleText = isExpanded ? '➖ ' : '➕ ';
        return $('<span/>')
        .attr('data-name', group)
        .css({
        'cursor': 'pointer',
        'color': '#0d6efd',
        'font-weight': 'bold',
        'display': 'block',
        'text-align': 'left'
        })
        .text(toggleText + group + ' (' + rows.count() + ' Employees)');
        }
        };
        }

        table = $('#EmployeeTable').DataTable(tableOptions);
        }


        // Live search: the directory updates as the user types — there is no Search button.
        // In virtual mode this filters the already-loaded data in memory (instant, no request);
        // in the other modes it re-queries the server (debounced so we don't fire per keystroke).
        var _searchDebounce = null;
        function triggerSearch() {
        if (DIRECTORY_MODE === 'virtual') {
        applyClientFilter();                 // in-memory, zero network
        } else {
        clearTimeout(_searchDebounce);
        _searchDebounce = setTimeout(refreshDirectory, 200);
        }
        }

        // Search-panel input filters (keep only valid characters).
        // Name: letters and spaces only.
        $('#searchName').on('input', function () {
        $(this).val($(this).val().replace(/[^a-zA-Z\s]/g, ''));
        });

        // Employee ID: digits only.
        $('#searchId').on('input', function () {
        $(this).val($(this).val().replace(/[^0-9]/g, ''));
        });

        // Any change to a search field updates the directory live (the strip handlers above run first).
        $('#searchName, #searchId, #searchStartDate, #searchEndDate').on('input change', triggerSearch);


        $('#EmployeeTable tbody').on('click', 'tr.dtrg-start', function () {
        if (!table) return; // only relevant in eager (rowGroup) mode
        var name = $(this).find('span').attr('data-name'); // We find the span we injected above to grab the department name
        if (name) {
        expandedGroups[name] = !expandedGroups[name];
        table.draw(false);
        }
        });

        // Clear Button: reset all filters, then refresh live (search itself is automatic now).
        $('#btnClear').on('click', function () {
        $('#searchName').val('');
        $('#searchId').val('');
        $('#searchStartDate').val('');
        $('#searchEndDate').val('');
        triggerSearch(); // re-render without filters
        });


        // --- 5. EXCEL-STYLE BULK ENTRY LOGIC ---

        // 1. Template for a blank row
        // 1. Template for a blank row (FIXED COLUMN ALIGNMENTS)
        // 1. Template for a blank row
        function getNewRowHtml() {
        return `
        <tr class="excel-row">
        <td><input type="text" class="form-control form-control-sm excel-name" placeholder="Full Name..." required /></td>
        <td>
        <div class="input-group input-group-sm">
        <select class="form-select excel-code" style="max-width: 100px;">${COUNTRY_OPTIONS}</select>
        <input type="text" class="form-control excel-phone" placeholder="Phone number..." minlength="4" maxlength="14" required />
        </div>
        </td>
        <td><input type="number" class="form-control form-control-sm excel-age" placeholder="Age..." min="18" max="100" required /></td>
        <td><input type="text" class="form-control form-control-sm excel-address" placeholder="Enter address..." minlength="10" required /></td>
        <td>
        <select class="form-select form-select-sm excel-gender" required>
        <option value="">Select Gender...</option>
        <option value="Male">Male</option>
        <option value="Female">Female</option>
        <option value="Other">Other</option>
        </select>
        </td>
        <td>
        <select class="form-select form-select-sm excel-dept" required>
        <option value="">Select Deptartment</option>
        <option value="Sales & Business">Sales & Business</option>
        <option value="Client Relations & Operations">Client Relations & Operations</option>
        <option value="Software & IT">Software & IT</option>
        <option value="Marketing">Marketing</option>
        <option value="HR">HR</option>
        </select>
        </td>
        <td><input type="date" class="form-control form-control-sm excel-date" value="${currentDateString}" min="2018-01-01" max="${maxDateString}" required /></td>
        <td>
        <select class="form-select form-select-sm excel-status" required>
        <option value="">Select Status...</option>
        <option value="Full time">Full time</option>
        <option value="Part time">Part time</option>
        <option value="Freelance">Freelance</option>
        <option value="Seasonal">Seasonal</option>
        <option value="Intern">Intern</option>
        <option value="Other">Other</option>
        </select>
        </td>
        <td class="text-center"><button type="button" class="btn btn-sm btn-danger btn-remove-row">✖</button></td>
        </tr>
        `;
        }

        // 2. Add the first blank row immediately when the page loads
        $('#bulkEntryTable tbody').append(getNewRowHtml());

        // 3. Add Row Button
        $('#btnAddRow').on('click', function () {

        let lastRow = $('#bulkEntryTable tbody tr:last');

        if (lastRow.length > 0) {
        const errors = getRowErrors(lastRow);

        // If the last row is incomplete or invalid, stop and tell the user exactly why
        if (errors.length > 0) {
        Swal.fire({
        title: 'Incomplete Row',
        html: 'Please fix the last row before adding a new one:<br/><br/>' + errors.join('<br/>'),
        icon: 'warning'
        });
        return;
        }
        }

        // If everything is filled out, add the new blank row
        $('#bulkEntryTable tbody').append(getNewRowHtml());
        });

        // 4. Remove Row Button (Using event delegation because rows are dynamic)
        $('#bulkEntryTable').on('click', '.btn-remove-row', function () {
        // Only allow removing if there is more than 1 row
        if ($('#bulkEntryTable tbody tr').length > 1) {
        $(this).closest('tr').remove();
        } else {
        Swal.fire('Hold on', 'You must have at least one row.', 'warning');
        }
        });


        // 5. Apply the Real-Time Input Filters to the DYNAMIC rows
        // Name: Letters and spaces only
        $('#bulkEntryTable').on('input', '.excel-name', function () {
        $(this).val($(this).val().replace(/[^a-zA-Z\s]/g, ''));
        });

        // Age: Numbers only AND strictly limit to 100
        $('#bulkEntryTable').on('input', '.excel-age', function () {
        let value = $(this).val().replace(/[^0-9]/g, '');

        // If they type a number higher than 100, instantly lock it to 100
        if (parseInt(value) > 100) {
        value = '100';
        }

        $(this).val(value);
        });

        // Phone: Numbers only. National numbers vary in length across countries, so cap at
        // 14 digits (E.164 allows a national number of at most 15 minus the country code).
        $('#bulkEntryTable').on('input', '.excel-phone', function () {
        let value = $(this).val().replace(/[^0-9]/g, '');
        if (value.length > 14) {
        value = value.slice(0, 14); // Trim anything past the E.164 maximum
        }
        $(this).val(value);
        });

        // Immediate phone feedback: flag the field red as soon as the user leaves it (or
        // switches country code) if it doesn't satisfy that country's rules.
        function flagPhone($input) {
        const code = $input.closest('tr').find('.excel-code').val();
        const value = ($input.val() || '').trim();
        const err = value ? validatePhoneClient(code, value) : null;
        if (err) {
        $input.addClass('is-invalid').attr('title', err);
        } else {
        $input.removeClass('is-invalid').removeAttr('title');
        }
        }

        $('#bulkEntryTable').on('blur', '.excel-phone', function () {
        flagPhone($(this));
        });

        $('#bulkEntryTable').on('change', '.excel-code', function () {
        flagPhone($(this).closest('tr').find('.excel-phone'));
        });

        // 6. SAVE ALL LOGIC
        $('#btnSaveBatch').on('click', function () {

        // Validate every row up-front, and catch duplicate phone numbers within the grid,
        // so problems are reported clearly here instead of as a generic database rejection.
        var allErrors = [];
        var phoneRows = {}; // full phone number -> [row numbers using it]

        $('#bulkEntryTable tbody tr').each(function (index) {
        var row = $(this);
        var rowNo = index + 1;

        getRowErrors(row).forEach(function (e) {
        allErrors.push('Row ' + rowNo + ': ' + e);
        });

        var fullPhone = row.find('.excel-code').val() + ' ' + (row.find('.excel-phone').val() || '').trim();
        (phoneRows[fullPhone] = phoneRows[fullPhone] || []).push(rowNo);
        });

        Object.keys(phoneRows).forEach(function (phone) {
        var rowsUsing = phoneRows[phone];
        if (rowsUsing.length > 1) {
        allErrors.push('Duplicate phone number "' + phone + '" used in rows ' + rowsUsing.join(', ') + '. Each employee must have a unique number.');
        }
        });

        if (allErrors.length > 0) {
        Swal.fire({ title: 'Please fix these issues', html: allErrors.join('<br/>'), icon: 'error' });
        return;
        }

        // Build the JSON Array
        var employeesArray = [];
        $('#bulkEntryTable tbody tr').each(function () {
        var row = $(this);

        // Construct the Employee object matching your C# Model
        var emp = {
        FullName: row.find('.excel-name').val(),
        CountryCode: row.find('.excel-code').val(),
        PhoneNumber: row.find('.excel-code').val() + " " + row.find('.excel-phone').val(),
        Age: parseInt(row.find('.excel-age').val()),
        Address: row.find('.excel-address').val(),
        Gender: row.find('.excel-gender').val(),
        Department: row.find('.excel-dept').val(),
        AdmissionDate: row.find('.excel-date').val(),
        EmploymentStatus: row.find('.excel-status').val()
        };

        employeesArray.push(emp);
        });

        // Send to C# Database
        Swal.fire({
        title: 'Save Batch?',
        text: `You are about to save ${employeesArray.length} employees.`,
        icon: 'question',
        showCancelButton: true,
        confirmButtonText: 'Yes, Save All!'
        }).then((result) => {
        if (result.isConfirmed) {

        // Loading popup: the server still has to validate every number and write to the DB,
        // which can take a moment. Show a spinner so the user knows work is happening.
        Swal.fire({
        title: 'Saving to database…',
        html: 'Please wait while your employees are validated and saved.',
        allowOutsideClick: false,
        allowEscapeKey: false,
        didOpen: () => { Swal.showLoading(); }
        });

        $.ajax({
        url: '/Employee/SaveMultipleEmployees',
        type: 'POST',
        contentType: 'application/json', // CRITICAL for lists
        data: JSON.stringify(employeesArray),
        success: function (response) {
        if (response.success) {
        Swal.fire('Saved!', response.message, 'success');

        // Reset the grid back to 1 empty row
        $('#bulkEntryTable tbody').empty();
        $('#bulkEntryTable tbody').append(getNewRowHtml());

        // Refresh the directory (folders in lazy mode, DataTable otherwise)
        refreshDirectory();
        } else {
        Swal.fire({ title: 'Validation Error!', html: response.message, icon: 'error' });
        }
        },
        error: function () {
        Swal.fire('Error!', 'An error occurred connecting to the database.', 'error');
        }
        });
        }
        });
        });
        });
    </script>
</body>
</html>